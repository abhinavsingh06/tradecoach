{
  "expo": {
    "name": "TradeCoach",
    "slug": "tradecoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "tradecoach",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tradecoach.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "TradeCoach uses the microphone to record voice journal entries that are transcribed into your trade notes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tradecoach.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B1220",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "tradecoach"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e51910a2-1ea5-4389-abad-61a58048d7eb"
      }
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "TradeCoach uses the microphone to record voice journal entries that are transcribed into your trade notes."
        }
      ]
    ],
    "owner": "abhinavsingh9986"
  }
}
