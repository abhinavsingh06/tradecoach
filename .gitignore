# Expo / React Native app — owns its own framework + build rules.
# See https://docs.expo.dev/distribution/app-stores/

# --- Dependencies ---
node_modules/

# --- Expo ---
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# --- EAS build artifacts ---
*.apk
*.aab
*.ipa

# --- Native ---
# Generated by `expo prebuild`; safe to ignore unless you eject.
/ios
/android
.kotlin/
*.orig.*

# --- Signing / keystores (NEVER commit) ---
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
!debug.keystore

# --- Metro / Hermes caches ---
.metro-health-check*
.haste_cache/

# --- TypeScript ---
*.tsbuildinfo

# --- Local env (project-scoped; the root .gitignore also covers it) ---
.env
.env.local
.env.*.local
!.env.example

# --- Debug logs ---
npm-debug.*
yarn-debug.*
yarn-error.*

# --- OS (project-scoped; root also covers it) ---
.DS_Store
