# Backend URL the mobile app talks to.
#
# • Simulator: http://localhost:4000
# • Physical device on the same Wi-Fi: http://<your-mac-LAN-IP>:4000
#   (`localhost` resolves to the phone itself, not your dev machine)
# • Production (already configured in eas.json for `preview` + `production`
#   profiles): https://tradecoach-api.onrender.com
#
# All AI / LLM keys live exclusively on the backend (see ../tradecoach-server/.env)
# so the mobile app never ships a secret.
EXPO_PUBLIC_API_URL=http://localhost:4000
